  decisionRef            String
  outcomeWindow          String
  realizedPnl            Float?
  realizedSlippageBps    Float?
  forecastAccuracy       Float?
  attribution            Json
  driftFlags             String[] @default([])
  recommendedUpdateScope String
  createdAt              DateTime @default(now())

  @@index([decisionRef, createdAt])
  @@schema("apex")
}

model ModelRegistry {
