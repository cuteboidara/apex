generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["apex"]
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  hashedPassword  String
  role            String    @default("MEMBER")
  status          String    @default("PENDING")
  approvedAt      DateTime?
  approvedBy      String?
  suspendedReason String?
  lastLoginAt     DateTime?
  loginCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  @@schema("apex")
}

model Setup {
  id        String    @id @default(cuid())
  asset     String
  direction String
  rank      String
  total     Int
  macro     Int
  structure Int
  zones     Int
  technical Int
  timing    Int
  reasoning String?
  createdAt DateTime  @default(now())
  tradeLog  TradeLog?
  @@schema("apex")
}

model TradeLog {
  id      String  @id @default(cuid())
  setupId String  @unique
  setup   Setup   @relation(fields: [setupId], references: [id])
  entry   Float?
  exit    Float?
  pnl     Float?
  notes   String?
  outcome String?
  @@schema("apex")
}

model Signal {
  id           String   @id @default(cuid())
  runId        String
  run          SignalRun @relation(fields: [runId], references: [id])
  asset        String
  assetClass   String
  direction    String
  rank         String
  total        Int
  macro        Int
  structure    Int
  zones        Int
  technical    Int
  timing       Int
  entry        Float?
  stopLoss     Float?
  tp1          Float?
  tp2          Float?
  tp3          Float?
  brief        String
  rawData      Json
  sentTelegram Boolean  @default(false)
  createdAt    DateTime @default(now())

  // 3-stage AI analysis pipeline fields
  aiExplanation       String?
  aiRiskAssessment    String?
  aiMarketContext     String?
  aiEntryRefinement   String?
  aiInvalidationLevel String?
  aiUnifiedAnalysis   String?
  aiGptConfidence     Int?
  aiClaudeConfidence  Int?
  aiGeminiConfidence  Int?
  aiVerdict           String?
  aiGeneratedAt       DateTime?

  alerts       Alert[]
  tradePlans   TradePlan[]
  @@schema("apex")
}

model TelegramSettings {
  id                String   @id @default(cuid())
  enabled           Boolean  @default(true)
  minRank           String   @default("A")
  allowedAssets     String   @default("ALL")
  weekendCryptoOnly Boolean  @default(false)
  updatedAt         DateTime @updatedAt
  @@schema("apex")
}

model SignalRun {
  id                      String   @id @default(cuid())
  queuedAt                DateTime @default(now())
  startedAt               DateTime?
  completedAt             DateTime?
  totalDurationMs         Int?
  dataFetchDurationMs     Int?
  scoringDurationMs       Int?
  persistenceDurationMs Int?
  alertDispatchDurationMs Int?
  engineVersion           String
  featureVersion          String
  promptVersion           String
  status                  String
  failureCode             String?
  failureReason           String?
  failureDetails          Json?
  signals                 Signal[]
  tradePlans              TradePlan[]
  @@schema("apex")
}

model DailySignalRun {
  id                String   @id @default(cuid())
  windowKey         String   @unique
  runDate           String
  timezone          String
  scheduledFor      DateTime
  startedAt         DateTime?
  completedAt       DateTime?
  triggeredBy       String
  mode              String
  status            String
  forced            Boolean  @default(false)
  dryRun            Boolean  @default(false)
  zeroSignalDay     Boolean  @default(false)
  generatedCount    Int      @default(0)
  publishedCount    Int      @default(0)
  deliveredCount    Int      @default(0)
  failedCount       Int      @default(0)
  signalSnapshot    Json?
  publicationPolicy Json?
  errorCode         String?
  errorMessage      String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  deliveries        DailySignalDelivery[]

  @@index([runDate, timezone])
  @@index([status, scheduledFor])
  @@schema("apex")
}

model DailySignalDelivery {
  id               String   @id @default(cuid())
  dailySignalRunId String
  channel          String
  target           String
  dedupeKey        String   @unique
  status           String
  signalCount      Int      @default(0)
  attempts         Int      @default(0)
  lastAttemptAt    DateTime?
  deliveredAt      DateTime?
  errorCode        String?
  errorMessage     String?
  payloadSnapshot  Json?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  dailySignalRun   DailySignalRun @relation(fields: [dailySignalRunId], references: [id])

  @@index([dailySignalRunId, status])
  @@index([channel, status, createdAt])
  @@schema("apex")
}

model TradePlan {
  id                         String    @id @default(cuid())
  runId                      String
  run                        SignalRun @relation(fields: [runId], references: [id])
  signalId                   String
  signal                     Signal    @relation(fields: [signalId], references: [id])
  symbol                     String
  assetClass                 String
  style                      String
  setupFamily                String?
  bias                       String
  confidence                 Int
  timeframe                  String
  entryType                  String
  entryMin                   Float?
  entryMax                   Float?
  stopLoss                   Float?
  takeProfit1                Float?
  takeProfit2                Float?
  takeProfit3                Float?
  riskRewardRatio            Float?
  invalidationLevel          Float?
  regimeTag                  String?
  liquidityThesis            String?
  trapThesis                 String?
  setupScore                 Int?
  publicationRank            String?
  thesis                     String
  executionNotes             String
  status                     String
  providerAtSignal           String?
  providerHealthStateAtSignal String?
  providerMarketStatusAtSignal String?
  providerFallbackUsedAtSignal Boolean   @default(false)
  qualityGateReason          String?
  detectedAt                 DateTime?
  entryHitAt                 DateTime?
  stopHitAt                  DateTime?
  tp1HitAt                   DateTime?
  tp2HitAt                   DateTime?
  tp3HitAt                   DateTime?
  invalidatedAt              DateTime?
  expiredAt                  DateTime?
  maxFavorableExcursion      Float?
  maxAdverseExcursion        Float?
  realizedRR                 Float?
  outcome                    String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@unique([signalId, style])
  @@index([symbol, detectedAt])
  @@index([style, outcome])
  @@index([providerHealthStateAtSignal])
  @@schema("apex")
}

model Alert {
  id            String   @id @default(cuid())
  signalId       String
  signal         Signal   @relation(fields: [signalId], references: [id])
  channel        String
  recipient      String
  status         String
  attemptedAt    DateTime?
  deliveredAt    DateTime?
  failureReason  String?
  retryCount     Int      @default(0)
  createdAt      DateTime @default(now())
  @@schema("apex")
}

model TelegramSubscriber {
  id            String    @id @default(cuid())
  chatId        String    @unique
  username      String?
  firstName     String?
  lastName      String?
  languageCode  String?
  tier          String    @default("FREE")
  status        String    @default("ACTIVE")
  alertsEnabled Boolean   @default(true)
  alertAssets   String[]  @default([])
  alertRanks    String[]  @default(["S", "A", "B"])
  startedAt     DateTime  @default(now())
  lastActiveAt  DateTime  @default(now())
  messageCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@schema("apex")
}

model ProviderHealth {
  id             String   @id @default(cuid())
  provider       String
  requestSymbol  String?
  detail         String?
  latencyMs      Int?
  errorRate      Float?
  quotaRemaining Int?
  status         String
  recordedAt     DateTime @default(now())
  @@schema("apex")
}

model MarketDataSnapshot {
  id             String   @id @default(cuid())
  symbol         String
  assetClass     String
  timeframe      String
  provider       String
  selected       Boolean  @default(false)
  fallbackUsed   Boolean  @default(false)
  price          Float?
  open           Float?
  high           Float?
  low            Float?
  close          Float?
  volume         Float?
  freshnessMs    Int?
  marketStatus   String
  reason         String?
  capturedAt     DateTime @default(now())

  @@index([symbol, timeframe, capturedAt])
  @@schema("apex")
}

model ProviderCircuitState {
  id            String   @id @default(cuid())
  provider      String
  assetClass    String
  state         String
  score         Int      @default(100)
  failureCount  Int      @default(0)
  successCount  Int      @default(0)
  errorStreak   Int      @default(0)
  openedAt      DateTime?
  lastFailureAt DateTime?
  lastSuccessAt DateTime?
  cooldownUntil DateTime?
  updatedAt     DateTime @updatedAt

  @@unique([provider, assetClass])
  @@schema("apex")
}

model AuditEvent {
  id            String   @id @default(cuid())
  actor         String
  action        String
  entityType    String
  entityId      String
  before        Json?
  after         Json?
  correlationId String?
  timestamp     DateTime @default(now())
  @@schema("apex")
}

model ExplanationCache {
  id            String   @id @default(cuid())
  fingerprint   String
  purpose       String
  status        String
  provider      String
  fallbackUsed  Boolean  @default(false)
  fallbackChain Json?
  content       String
  errorMetadata Json?
  generatedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([fingerprint, purpose])
  @@index([purpose, updatedAt])
  @@schema("apex")
}

model Candle {
  id              String   @id @default(cuid())
  symbol          String
  assetClass      String
  timeframe       String
  provider        String
  requestSymbol   String?
  sourceTimestamp DateTime
  recordedAt      DateTime @default(now())
  open            Float
  high            Float
  low             Float
  close           Float
  volume          Float?
  quality         String   @default("LIVE")
  metadata        Json?

  @@unique([symbol, timeframe, provider, sourceTimestamp])
  @@index([symbol, timeframe, sourceTimestamp])
  @@index([provider, sourceTimestamp])
  @@schema("apex")
}

model QuoteSnapshot {
  id              String   @id @default(cuid())
  symbol          String
  assetClass      String
  provider        String
  requestSymbol   String?
  sourceTimestamp DateTime
  recordedAt      DateTime @default(now())
  price           Float
  bid             Float?
  ask             Float?
  change24h       Float?
  high14d         Float?
  low14d          Float?
  volume          Float?
  freshnessMs     Int?
  marketStatus    String
  reason          String?
  metadata        Json?

  @@unique([symbol, provider, sourceTimestamp])
  @@index([symbol, sourceTimestamp])
  @@index([provider, sourceTimestamp])
  @@schema("apex")
}

model RegimeSnapshot {
  id              String   @id @default(cuid())
  symbol          String
  assetClass      String
  timeframe       String
  regimeTag       String
  bias            String?
  score           Int
  clarity         String
  rangePct        Float?
  sourceTimestamp DateTime
  runId           String?
  signalId        String?
  tradePlanId     String?
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([symbol, timeframe, sourceTimestamp])
  @@index([runId])
  @@index([tradePlanId])
  @@schema("apex")
}

model TradeOutcome {
  id                         String   @id @default(cuid())
  tradePlanId                String   @unique
  signalId                   String
  runId                      String
  symbol                     String
  assetClass                 String
  style                      String
  setupFamily                String?
  bias                       String
  confidence                 Int
  providerAtSignal           String?
  providerHealthStateAtSignal String?
  regimeTag                  String?
  outcome                    String
  entryPrice                 Float?
  exitPrice                  Float?
  realizedPnl                Float?
  realizedRR                 Float?
  maxFavorableExcursion      Float?
  maxAdverseExcursion        Float?
  openedAt                   DateTime?
  closedAt                   DateTime?
  metadata                   Json?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([symbol, closedAt])
  @@index([style, outcome])
  @@index([regimeTag])
  @@index([providerAtSignal, providerHealthStateAtSignal])
  @@schema("apex")
}

model StrategyPerformanceWindow {
  id                  String   @id @default(cuid())
  scopeType           String
  symbol              String?
  assetClass          String?
  style               String?
  setupFamily         String?
  regimeTag           String?
  provider            String?
  providerHealthState String?
  lookbackDays        Int
  sampleSize          Int
  winRate             Float?
  averageRR           Float?
  expectancy          Float?
  maxDrawdown         Float?
  confidenceMean      Float?
  generatedAt         DateTime @default(now())

  @@index([scopeType, generatedAt])
  @@index([symbol, style, generatedAt])
  @@index([setupFamily, regimeTag, generatedAt])
  @@schema("apex")
}

model ConfidenceCalibrationBucket {
  id          String   @id @default(cuid())
  scopeType   String
  symbol      String?
  assetClass  String?
  style       String?
  setupFamily String?
  regimeTag   String?
  provider    String?
  confidenceMin Int
  confidenceMax Int
  sampleSize  Int
  winRate     Float?
  averageRR   Float?
  expectancy  Float?
  generatedAt DateTime @default(now())

  @@index([scopeType, generatedAt])
  @@index([symbol, style, generatedAt])
  @@index([setupFamily, regimeTag, generatedAt])
  @@schema("apex")
}

model PaperAccount {
  id              String   @id @default(cuid())
  ownerUserId     String?
  teamId          String?
  name            String
  currency        String   @default("USD")
  startingBalance Float    @default(10000)
  cashBalance     Float    @default(10000)
  equity          Float    @default(10000)
  status          String   @default("ACTIVE")
  isDefault       Boolean  @default(false)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerUserId, status])
  @@index([teamId, status])
  @@schema("apex")
}

model PaperPosition {
  id              String   @id @default(cuid())
  accountId       String
  tradePlanId     String?
  signalId        String?
  symbol          String
  assetClass      String
  status          String
  direction       String
  quantity        Float
  entryPrice      Float
  stopLoss        Float?
  takeProfit1     Float?
  takeProfit2     Float?
  takeProfit3     Float?
  currentPrice    Float?
  unrealizedPnl   Float?
  realizedPnl     Float    @default(0)
  openedAt        DateTime @default(now())
  closedAt        DateTime?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([accountId, status])
  @@index([symbol, status])
  @@index([tradePlanId])
  @@schema("apex")
}

model ExecutionFill {
  id          String   @id @default(cuid())
  accountId   String
  positionId  String?
  tradePlanId String?
  signalId    String?
  symbol      String
  assetClass  String
  side        String
  quantity    Float
  price       Float
  fee         Float?   @default(0)
  slippageBps Float?
  spreadBps   Float?
  mode        String   @default("PAPER")
  venue       String?
  provider    String?
  occurredAt  DateTime @default(now())
  metadata    Json?

  @@index([accountId, occurredAt])
  @@index([positionId, occurredAt])
  @@index([tradePlanId])
  @@schema("apex")
}

model AlertDeliveryAttempt {
  id                String   @id @default(cuid())
  alertId           String
  channel           String
  recipient         String
  status            String
  latencyMs         Int?
  providerMessageId String?
  providerResponse  String?
  detail            String?
  attemptedAt       DateTime @default(now())

  @@index([alertId, attemptedAt])
  @@index([channel, attemptedAt])
  @@schema("apex")
}

model DeadLetterJob {
  id            String   @id @default(cuid())
  queueName     String
  jobId         String   @unique
  runId         String?
  status        String   @default("FAILED")
  attemptsMade  Int      @default(0)
  reason        String
  payload       Json?
  correlationId String?
  failedAt      DateTime @default(now())
  replayedAt    DateTime?
  replayStatus  String?
  metadata      Json?

  @@index([queueName, failedAt])
  @@index([runId])
  @@schema("apex")
}

model OperationalMetric {
  id         String   @id @default(cuid())
  metric     String
  category   String
  severity   String?
  unit       String?
  value      Float?
  count      Int?
  provider   String?
  symbol     String?
  assetClass String?
  runId      String?
  detail     String?
  tags       Json?
  recordedAt DateTime @default(now())

  @@index([metric, recordedAt])
  @@index([category, recordedAt])
  @@index([provider, recordedAt])
  @@index([symbol, recordedAt])
  @@schema("apex")
}

model BacktestRun {
  id                String   @id @default(cuid())
  name              String
  requestedByUserId String?
  symbol            String?
  assetClass        String?
  timeframe         String
  status            String   @default("QUEUED")
  config            Json
  summary           Json?
  failureReason     String?
  startedAt         DateTime @default(now())
  completedAt       DateTime?

  @@index([status, startedAt])
  @@index([symbol, startedAt])
  @@schema("apex")
}

model BacktestTrade {
  id                   String   @id @default(cuid())
  backtestRunId        String
  symbol               String
  assetClass           String
  style                String
  signalTimestamp      DateTime
  entryTimestamp       DateTime?
  exitTimestamp        DateTime?
  provider             String?
  regimeTag            String?
  setupFamily          String?
  confidence           Int?
  outcome              String
  entryPrice           Float?
  exitPrice            Float?
  realizedPnl          Float?
  realizedRR           Float?
  maxFavorableExcursion Float?
  maxAdverseExcursion  Float?
  metadata             Json?

  @@index([backtestRunId, signalTimestamp])
  @@index([symbol, outcome])
  @@index([setupFamily, regimeTag])
  @@schema("apex")
}

model SubscriptionPlan {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  tier             String
  active           Boolean  @default(true)
  monthlyPriceCents Int?
  annualPriceCents Int?
  features         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@schema("apex")
}

model UserSubscription {
  id                    String   @id @default(cuid())
  userId                String
  planId                String
  status                String   @default("TRIAL")
  seatCount             Int      @default(1)
  billingCustomerId     String?
  billingSubscriptionId String?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  trialEndsAt           DateTime?
  featureOverrides      Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId, status])
  @@index([billingCustomerId])
  @@schema("apex")
}

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  ownerUserId String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@schema("apex")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      String   @default("MEMBER")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
  @@index([userId, status])
  @@schema("apex")
}

model ApiToken {
  id        String   @id @default(cuid())
  userId    String
  name      String
  tokenHash String   @unique
  scopes    String[] @default([])
  lastUsedAt DateTime?
  expiresAt DateTime?
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, revokedAt])
  @@schema("apex")
}

model WebhookEndpoint {
  id             String   @id @default(cuid())
  userId         String?
  teamId         String?
  name           String
  url            String
  secretHash     String?
  events         String[] @default([])
  status         String   @default("ACTIVE")
  lastDeliveredAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, status])
  @@index([teamId, status])
  @@schema("apex")
}

model ExportJob {
  id         String   @id @default(cuid())
  userId     String?
  teamId     String?
  format     String
  status     String   @default("QUEUED")
  scope      String
  filter     Json?
  filePath   String?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, status])
  @@index([teamId, status])
  @@schema("apex")
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
  @@schema("apex")
}

model WatchlistAsset {
  id         String   @id @default(cuid())
  watchlistId String
  symbol     String
  createdAt  DateTime @default(now())

  @@unique([watchlistId, symbol])
  @@schema("apex")
}

model UserPreference {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  timezone               String?
  quietHoursStart        Int?
  quietHoursEnd          Int?
  stylePreferences       String[] @default([])
  subscribedSymbols      String[] @default([])
  subscribedAssetClasses String[] @default([])
  alertsEnabled          Boolean  @default(true)
  emailDigestEnabled     Boolean  @default(false)
  webhookAlertsEnabled   Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  @@schema("apex")
}

model MarketEvent {
  id              String   @id @default(cuid())
  eventId         String   @unique
  tsExchange      DateTime
  tsReceived      DateTime
  venue           String
  symbolCanonical String
  assetClass      String
  eventType       String
  sequenceNumber  Int
  payload         Json
  integrityFlags  String[] @default([])
  createdAt       DateTime @default(now())

  @@index([symbolCanonical, tsExchange])
  @@index([venue, tsReceived])
  @@schema("apex")
}

model FeatureSnapshot {
  id              String   @id @default(cuid())
  snapshotId      String   @unique
  ts              DateTime
  symbolCanonical String
  horizon         String
  features        Json
  quality         Json
  createdAt       DateTime @default(now())

  @@index([symbolCanonical, ts])
  @@index([horizon, ts])
  @@schema("apex")
}

model PodOutput {
  id                 String   @id @default(cuid())
  podId              String
  ts                 DateTime
  symbolCanonical    String
  decisionHorizon    String
  signalType         String
  confidence         Float
  recommendedAction  String?
  expectedReturn     Float?
  expectedVolatility Float?
  winProbability     Float?
  urgency            Float?
  stateAssessment    String?
  constraints        Json
  diagnostics        Json
  modelVersion       String
  createdAt          DateTime @default(now())

  @@index([podId, ts])
  @@index([symbolCanonical, ts])
  @@schema("apex")
}

model AllocationIntent {
  id               String   @id @default(cuid())
  ts               DateTime
  symbolCanonical  String
  selectedPods     String[] @default([])
  podWeights       Json
  targetPosition   Float
  confidence       Float
  portfolioContext Json
  reasonCodes      String[] @default([])
  createdAt        DateTime @default(now())

  @@index([symbolCanonical, ts])
  @@schema("apex")
}

model RiskDecision {
  id                     String   @id @default(cuid())
  ts                     DateTime
  scope                  String
  symbolCanonical        String
  approvalStatus         String
  approvedSizeMultiplier Float
  riskCheckResults       Json
  overrideInstructions   String?
  deRiskingAction        String   @default("none")
  killSwitchActive       Boolean  @default(false)
  createdAt              DateTime @default(now())

  @@index([symbolCanonical, ts])
  @@index([approvalStatus, ts])
  @@schema("apex")
}

model ExecutionIntent {
  id                 String   @id @default(cuid())
  intentId           String   @unique
  ts                 DateTime
  symbolCanonical    String
  side               String
  targetSize         Float
  urgency            Float
  executionStyle     String
  slippageBudgetBps  Float
  constraints        Json
  fallbackStyle      String
  createdAt          DateTime @default(now())

  @@index([symbolCanonical, ts])
  @@schema("apex")
}

model ChildOrder {
  id                  String   @id @default(cuid())
  childOrderId        String   @unique
  intentId            String
  ts                  DateTime
  symbolCanonical     String
  side                String
  size                Float
  executionStyle      String
  limitPrice          Float?
  expectedSlippageBps Float
  status              String
  notes               String?
  createdAt           DateTime @default(now())

  @@index([intentId, ts])
  @@index([symbolCanonical, ts])
  @@schema("apex")
}

model DecisionJournal {
  id                 String   @id @default(cuid())
  decisionId         String   @unique
  ts                 DateTime
  symbolCanonical    String
  marketSnapshotRef  String
  podOutputRefs      String[] @default([])
  allocationRef      String
  riskDecisionRef    String
  executionIntentRef String
  finalAction        String
  humanSummary       String
  createdAt          DateTime @default(now())

  @@index([symbolCanonical, ts])
  @@index([finalAction, ts])
  @@schema("apex")
}

model IndicesSignal {
  id                 String   @id @default(cuid())
  cycleId            String
  assetId            String
  assetClass         String   // 'index' | 'forex'
  direction          String   // 'long' | 'short'
  rank               Int
  smcScore           Float
  taScore            Float
  macroScore         Float
  quantBonus         Float
  totalScore         Float
  entryZoneHigh      Float?
  entryZoneLow       Float?
  entryZoneMid       Float?
  stopLoss           Float?
  tp1                Float?
  tp2                Float?
  tp3                Float?
  riskRewardRatio    Float?
  positionSize       Float?
  riskAmount         Float?
  historicalWinRate  Float?
  expectedValue      Float?
  newsRisk           String   // 'clear' | 'caution' | 'blocked'
  reasoning          String?
  macroSummary       String?
  smcSetupJson       Json?
  taConfluenceJson   Json?
  macroScoreJson     Json?
  quantAnalysisJson  Json?
  correlationsJson   Json?
  sentTelegram       Boolean  @default(false)
  createdAt          DateTime @default(now())

  trades             IndicesTrade[]

  @@index([assetId, createdAt])
  @@index([totalScore, createdAt])
  @@index([cycleId])
  @@schema("apex")
}

model IndicesTrade {
  id              String   @id @default(cuid())
  signalId        String
  signal          IndicesSignal @relation(fields: [signalId], references: [id])
  assetId         String
  direction       String
  entryPrice      Float?
  entryTime       DateTime?
  exitPrice       Float?
  exitTime        DateTime?
  positionSize    Float?
  profitLoss      Float?
  returnPct       Float?
  status          String   @default("open") // 'open' | 'partial' | 'closed'
  tp1Hit          Boolean  @default(false)
  tp2Hit          Boolean  @default(false)
  tp3Hit          Boolean  @default(false)
  slHit           Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([assetId, createdAt])
  @@index([status, createdAt])
  @@schema("apex")
}

model LearningFeedback {
  id                     String   @id @default(cuid())
